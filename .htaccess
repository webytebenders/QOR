RewriteEngine On

# ── Force HTTPS (uncomment in production) ──
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# ── Strip .html from public URLs (301 redirect) ──
RewriteCond %{THE_REQUEST} \s/([^.]+)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L,QSA]

# ── Strip .php from admin URLs (301 redirect) ──
# Exclude API endpoints from redirect (they handle POST/AJAX)
RewriteCond %{THE_REQUEST} \s/(admin/api/.+)\.php[\s?] [NC]
RewriteRule ^ /%1 [R=301,L,QSA]

RewriteCond %{THE_REQUEST} \s/(admin/[^/]+)\.php[\s?] [NC]
RewriteRule ^ /%1 [R=301,L,QSA]

# ── Internal rewrite: extensionless → .html ──
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]

# ── Internal rewrite: extensionless → .php ──
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+)$ $1.php [L]
